msgid "Commands"
msgstr ""

#: ../../talk/bots.rst:21
msgid "Commands have been removed in favor of Bots."
msgstr ""

#: ../../talk/bots.rst:23
msgid "Nextcloud allows users to execute actions using commands. A command typically looks like:"
msgstr ""

