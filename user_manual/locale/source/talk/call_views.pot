#: ../../talk/call_views.rst:3
msgid "Call layout"
msgstr ""

#: ../../talk/call_views.rst:5
msgid "You can switch between grid view and speaker view using the toggle icon in the three-dot menu or the bottom bar."
msgstr ""

#: ../../talk/call_views.rst:11
msgid "Grid view"
msgstr ""

#: ../../talk/call_views.rst:13
msgid "Grid view shows all participants as tiles. Use the navigation buttons on the left and right to scroll through participants when they do not all fit on the screen."
msgstr ""

#: ../../talk/call_views.rst:19
msgid "Speaker view"
msgstr ""

#: ../../talk/call_views.rst:21
msgid "Speaker view (also called promoted view) centres the active speaker in a large tile and places the other participants in a row below. Use the navigation buttons on the left and right to scroll through participants when the row overflows."
msgstr ""
