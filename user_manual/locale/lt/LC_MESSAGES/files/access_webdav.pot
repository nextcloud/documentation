#: ../../files/access_webdav.rst:458
msgid "Select the saved certificate from the Desktop."
msgstr "Pasirinkite išsaugotą sertifikatą iš darbalaukio."

#: ../../files/access_webdav.rst:459
msgid ""
"Select Place all Certificates in the following Store, and click Browse."
msgstr ""
"Pasirinkite „Place all certificates in the following store“ ir spustelėkite "
