#: ../../files/access_webdav.rst:456
msgid "Dig down to Trust Root Certification Authorities, Certificates."
msgstr "Eiti iki „Trust Root Certification Authorities, Certificates“."

#: ../../files/access_webdav.rst:457
msgid "Right-Click Certificate, Select All Tasks, and Import."
msgstr ""
"Dešiniuoju pelės klavišu spustelėkite „Certificates“, pasirinkite „All "
