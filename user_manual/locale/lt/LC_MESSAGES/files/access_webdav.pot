#: ../../files/access_webdav.rst:453
msgid "Go to File > Add/Remove Snap-In."
msgstr "Eikite į meniu „File“ > „Add/Remove Snap-In“."

#: ../../files/access_webdav.rst:454
msgid ""
"Select Certificates, Click 'Add', choose 'My User Account', then 'Finish', "
